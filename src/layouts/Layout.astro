---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <article class="paper">
        <h1>{title}</h1>
        <slot />
      </article>
    </main>
  </body>
</html>

<style is:global>
  :root {
    --paper-bg: rgba(255, 255, 255, 0.85);
    --primary-color: #336699;
    --missing-color: #cc0000;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    padding: 0;
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    background-image: url("/background.jpg");
    /* background-image: url("https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=1920&q=80"); */
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 2rem 1rem;
  }

  main {
    width: 100%;
    max-width: 800px;
  }

  .paper {
    background-color: var(--paper-bg);
    padding: 2rem;
    border-radius: 4px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    min-height: 80vh;
    position: relative;
  }

  h1 {
    margin-top: 0;
    color: #333;
    border-bottom: 1px solid #ddd;
    padding-bottom: 0.5rem;
  }

  /* TiddlyWiki Links Styling */
  .tc-tiddlylink {
    text-decoration: none;
    font-weight: 500;
  }

  .tc-tiddlylink-resolves {
    color: var(--primary-color);
  }

  .tc-tiddlylink-resolves:hover {
    text-decoration: underline;
  }

  .tc-tiddlylink-missing {
    color: var(--missing-color);
    cursor: help;
    border-bottom: 1px dotted var(--missing-color);
  }

  /* Mobile Optimizations */
  @media (max-width: 600px) {
    body {
      padding: 0.5rem;
    }
    .paper {
      padding: 1.5rem;
      min-height: 95vh;
    }
  }
  img {
    max-width: 100%;
    height: auto;
  }
</style>
